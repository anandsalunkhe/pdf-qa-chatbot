# .env.example
# Copy this file to .env and fill in your real API key.
#
#   cp .env.example .env
#
# The application uses the OpenAI Python SDK pointed at Gemini's
# OpenAI-compatible endpoint:
#   https://generativelanguage.googleapis.com/v1beta/openai/
#
# One API key is used for BOTH embeddings and chat completions.
# NEVER commit your real .env file to version control (it's in .gitignore).

# Your Gemini API key from Google AI Studio.
# Get one free at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
